# ── Required on Render ────────────────────────────────────────────────────────

# Your Vercel frontend URL — paste exactly from Vercel dashboard
FRONTEND_URL=https://lungdenoise.vercel.app

# Extra CORS origins (comma-separated), e.g. preview deployments
# EXTRA_ORIGINS=https://lungdenoise-git-main-yourname.vercel.app

# ── Database ─────────────────────────────────────────────────────────────────
# Option A — Neon (Vercel Postgres):
#   Copy "Connection string" from Neon console (use the pooled URL for serverless)
#   Format: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Render needs the DIRECT (non-pooled) URL for migrations:
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Option B — SQLite (local dev only, do NOT use in production):
# DATABASE_URL=sqlite+aiosqlite:///./lungdenoise.db

# ── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
USE_PRETRAINED_DNCNN=false
